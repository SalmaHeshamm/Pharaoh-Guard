# ------------------------------------------------------------------ #
# LLM provider — Groq API
# ------------------------------------------------------------------ #
# Get a key at https://console.groq.com/keys — fill it in below.
RRS_GROQ_API_KEY=
RRS_GROQ_BASE_URL=https://api.groq.com/openai/v1
# Alternatives: llama-3.1-8b-instant (faster/cheaper), gemma2-9b-it
RRS_LLM_MODEL=llama-3.3-70b-versatile
RRS_LLM_MAX_TOKENS=1024
RRS_LLM_TEMPERATURE=0.2
RRS_LLM_TIMEOUT_SECONDS=60.0

# ------------------------------------------------------------------ #
# Risk model integration — trained sklearn Pipeline (Notebook 04/05).
# Leave unset to use the default (../datascience/risk_model.joblib,
# ../datascience/feature_manifest.json) — only override if you move
# the artifacts elsewhere.
# ------------------------------------------------------------------ #
# RRS_RISK_MODEL_PATH=
# RRS_FEATURE_MANIFEST_PATH=
RRS_CRITICAL_ALERT_THRESHOLD=0.7

# ------------------------------------------------------------------ #
# Risk thresholds (mirrors risk_level_distribution buckets in the data)
# anything above RRS_RISK_SCORE_HIGH_MAX => Critical
# ------------------------------------------------------------------ #
RRS_RISK_SCORE_LOW_MAX=30.0
RRS_RISK_SCORE_MEDIUM_MAX=55.0
RRS_RISK_SCORE_HIGH_MAX=75.0

# Not wired to a poller yet (reserved for a future scheduled-monitoring mode)
RRS_MONITORING_POLL_INTERVAL_SECONDS=30
# Low | Medium | High | Critical — minimum level that triggers the agent pipeline
RRS_MONITORING_TRIGGER_LEVEL=High

# ------------------------------------------------------------------ #
# RAG / knowledge base
# ------------------------------------------------------------------ #
# chroma | faiss (faiss backend not implemented yet — keep as chroma)
RRS_VECTOR_DB_BACKEND=chroma
RRS_EMBEDDING_MODEL=all-MiniLM-L6-v2
RRS_RAG_TOP_K=4

# ------------------------------------------------------------------ #
# Notification / dispatch integrations
# Leave webhooks empty + dry_run=True until they're real and tested
# ------------------------------------------------------------------ #
RRS_SLACK_WEBHOOK_URL=
RRS_SMS_WEBHOOK_URL=
RRS_DISPATCH_DRY_RUN=True

# ------------------------------------------------------------------ #
# API server
# Note: only used if you run uvicorn without --host/--port flags yourself
# (the Dockerfile currently hardcodes 0.0.0.0:8000 regardless of these)
# ------------------------------------------------------------------ #
RRS_API_HOST=0.0.0.0
RRS_API_PORT=8000
# JSON array as a string. "*" is fine for local dev, lock this down in prod.
RRS_API_CORS_ORIGINS=["*"]
